# MatchPro v10 UNIFIED — Environment Variables Template
# Copy this to .env and fill in actual values for production
# NEVER commit .env to Git — it's in .gitignore

# ============================================================================
# DATABASE (Railway MySQL or PostgreSQL)
# ============================================================================

# Railway auto-generates this when you add MySQL/PostgreSQL plugin
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/matchpro

# ============================================================================
# AUTH & SECURITY (GENERATE NEW VALUES FOR PRODUCTION)
# ============================================================================

# JWT secret for session tokens (use: openssl rand -base64 32)
# MUST be rotated before production deployment
JWT_SECRET=CHANGE_ME_GENERATE_NEW_SECRET_32_CHARS_MIN

# ============================================================================
# GREEN API (WhatsApp Integration)
# ============================================================================

# Green API credentials (from console.green-api.com)
GREEN_API_ID=7105409203

# ROTATE THIS TOKEN BEFORE PRODUCTION
# Generate new token at: https://console.green-api.com
GREEN_API_TOKEN=CHANGE_ME_GENERATE_NEW_TOKEN

# Base URLs for Green API
GREEN_API_API_URL=https://7105.api.greenapi.com
GREEN_API_MEDIA_URL=https://7105.media.greenapi.com

# ============================================================================
# EMAIL CONFIGURATION (Optional — for automated reports)
# ============================================================================

# Gmail with App Passwords recommended
# Get app password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mmaisara@crystalpowerinvestment.com

# ROTATE THIS PASSWORD BEFORE PRODUCTION
SMTP_PASS=CHANGE_ME_GET_NEW_APP_PASSWORD

# Email sender display name
SMTP_FROM=MatchPro Reports <mmaisara@crystalpowerinvestment.com>

# Report recipients (comma-separated for multiple)
REPORT_EMAIL_TO=mmaisara@crystalpowerinvestment.com
REPORT_EMAIL_CC=chadane@crystalpowerexport.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node.js environment
NODE_ENV=production

# Server port (Railway sets this automatically)
PORT=3000

# Frontend URL (used for redirects, CORS)
FRONTEND_URL=https://matchpro-v10-railway-app.railway.app

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=https://matchpro-v10-railway-app.railway.app

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================================================
# FEATURE FLAGS (Version Manager v1-v10)
# ============================================================================

FEATURE_V1_CORE=true
FEATURE_V2_MY_ASSETS=true
FEATURE_V3_MY_SEARCH=true
FEATURE_V4_PROPERTY_FINDER=true
FEATURE_V5_DUBIZZLE=true
FEATURE_V6_FACEBOOK=false
FEATURE_V7_CROSS_MARKET=false
FEATURE_V8_ENTERPRISE=false
FEATURE_V9_AI_EYE=false
FEATURE_V10_SAAS=false

# ============================================================================
# OPTIONAL: AWS S3 (for file uploads)
# ============================================================================

# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=matchpro-uploads

# ============================================================================
# NOTES FOR PRODUCTION
# ============================================================================

# 1. NEVER use these example values in production
# 2. Generate new JWT_SECRET: openssl rand -base64 32
# 3. Rotate GREEN_API_TOKEN at console.green-api.com
# 4. Get Gmail app password from myaccount.google.com/apppasswords
# 5. Set NODE_ENV=production for Railway deployments
# 6. Use Railway's built-in SECRET management for credentials
# 7. Rotate credentials every 90 days
# 8. Log all credential rotations in SECURITY.md
